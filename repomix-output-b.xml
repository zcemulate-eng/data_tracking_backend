  async create(@Body() createData: CreateUserDto, @Req() req: Request) {
    const userId = req.cookies['userId'];
    return this.usersService.create(createData, userId);
  }

  @ApiOperation({ summary: '更新用户信息' })
  @ApiCookieAuth()
  @Put(':id')
